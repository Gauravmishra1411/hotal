rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /hotel-documents/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Anyone can read images/videos
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
